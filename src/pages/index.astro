---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CollectionFilter from '@components/CollectionFilter.astro';
import RepoCard from '@components/RepoCard.astro';
import CodePenCard from '@components/CodePenCard.astro';
import CardSlider from '@components/CardSlider.astro';
import ToolIcon from '@components/ToolIcon.astro';
import { cacheCodePenThumbnails } from '@lib/cache-thumbnails';

const rawRepos = await getCollection('repos');
const repos = rawRepos.sort((a, b) => b.data.stars - a.data.stars);
const codepenUser = 'emilandersson';
const pens = [
  { slug: 'bNNOYyK', title: 'The Amazing Stress Ball' },
  { slug: 'OPXEMWV', title: 'Loading Bar Animation' },
  { slug: 'LEEvLxJ', title: 'Amazing Tilt Cards' },
  { slug: 'jEbOKed', title: 'Stacked Cards' },
  { slug: 'qEONMJa', title: 'CSS-Only Carousel Slider' },
  { slug: 'bNVEZgr', title: 'Captcha Slider Concept' },
  { slug: 'pvJyNrm', title: 'Expanding Dots (GSAP)' },
  { slug: 'GggeONK', title: 'Animated Radio Buttons' }

];
const thumbCache = await cacheCodePenThumbnails(codepenUser, pens.map((p) => p.slug));
---

<BaseLayout title="Home" description="Emil Andersson — developer portfolio & projects">
  <section class="hero-section flex-column gap-lg">

    <h1 class="hero-scramble scramble font-display" data-scramble-speed="1.3" aria-label="Hi, I'm Emil / Moxo">
      <span class="scramble-seg" data-text="Hi, I'm">Hi, I'm</span> <span class="scramble-seg gradient-text" data-text="Emil">Emil</span> <span class="scramble-sep">/</span> <span class="scramble-seg gradient-text" data-text="Moxo">Moxo</span>
    </h1>
    <p class="hero-subtitle scramble" data-scramble-speed="1.6" data-scramble-delay="400" aria-label="Full-stack developer building tools, game mods, web experiences, and creating music.">
      <span class="scramble-seg" data-text="Full-stack developer building tools, game mods, web experiences, and creating music.">Full-stack developer building tools, game mods, web experiences, and creating music.</span>
    </p>
    <div class="flex justify-center gap-md" data-hero-buttons style="opacity: 0">
      <a href="https://github.com/emilanderss0n" target="_blank" rel="noopener noreferrer"
         class="btn">
        <svg class="icon-sm" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <a href="/about" class="btn reversed">
        <span>About me →</span>
      </a>
    </div>
  </section>

  <section>
    <div class="section-title">
      <div class="flex gap-md section-title-main-text">
        <div class="icon-square sm">
          <ToolIcon name="GitHub" class="section-title-icon icon-sm anim-fade-up" style="--anim-delay: 1400ms" />
        </div>
        <h2 class="anim-fade-up" style="--anim-delay: 1400ms">GitHub Projects</h2>
      </div>
      <div class="anim-fade-up" style="--anim-delay: 1520ms; width: 100%;">
        <CollectionFilter target="#repo-grid-grouped" filterKey="lang" allLabel="All Languages" />
      </div>
    </div>

    <div id="repo-grid-grouped" class="flex-column">
      {
        (() => {
          const categories = [
            { key: 'game-development', label: 'Game Development' },
            { key: 'web-development', label: 'Web Development' },
            { key: 'other', label: 'Other Projects' },
          ];

          // Continuous stagger cascade across headings + cards
          let cursor = 1620;
          const HEAD_GAP = 120;
          const CARD_STEP = 50;
          const GROUP_GAP = 150;

          return categories.map((cat) => {
            const catRepos = repos.filter((r) => r.data.category === cat.key);
            if (catRepos.length === 0) return null;

            const headingDelay = cursor;
            const firstCardDelay = cursor + HEAD_GAP;
            cursor = firstCardDelay + Math.max(0, catRepos.length - 1) * CARD_STEP + GROUP_GAP;

            return (
              <div class="repo-group flex-column" data-filter-group>
                <div class="repo-category-wrapper flex">
                  <h3 class="repo-category small-title anim-fade-up" style={`--anim-delay: ${headingDelay}ms`}>{cat.label}</h3>
                  <div class="spacer-block"></div>
                </div>
                <div class="grid main-grid" style="--grid-max-col-count: 3; gap: 0;">
                  {catRepos.map((repo, i) => (
                    <RepoCard repo={repo} delay={firstCardDelay + i * CARD_STEP} />
                  ))}
                </div>
              </div>
            );
          });
        })()
      }
    </div>
    <p class="small-text hidden" id="no-match-lang">No repos match this filter.</p>
  </section>

  <section class="spacer-block"></section>

  <div class="spacer spacer-1">
    <div class="services grid" style="--grid-max-col-count: 2; gap: 0;">
      <div class="card dotted-card flex-column gap-md" style="--color: rgb(255, 126, 206);">
        <div class="flex gap-md">
          <div class="icon-square sm">
            <ToolIcon name="UI Design" class="service-icon icon-sm" />
          </div>
          <h3>UI Design</h3>
        </div>
        <p>
          Thoughtful interfaces that turn complex ideas into clear, intuitive experiences.
        </p>
      </div>
      <div class="card dotted-card flex-column gap-md" style="--color: rgb(126, 244, 255);">
        <div class="flex gap-md">
          <div class="icon-square sm">
            <ToolIcon name="Web Development" class="service-icon icon-sm" />
          </div>
          <h3>Web Development</h3>
        </div>
        <p>
          Fast, responsive websites and applications built around your goals, content, and audience.
        </p>
      </div>
      <div class="card dotted-card flex-column gap-md" style="--color: rgb(181, 255, 111);">
        <div class="flex gap-md">
          <div class="icon-square sm">
            <ToolIcon name="3D Art" class="service-icon icon-sm" />
          </div>
          <h3>3D Art</h3>
        </div>
        <p>
          Digital worlds, assets, and visual concepts shaped with a mix of craft and curiosity.
        </p>
      </div>
      <div class="card dotted-card flex-column gap-md" style="--color: rgb(177, 126, 244);">
        <div class="flex gap-md">
          <div class="icon-square sm">
            <ToolIcon name="Video Editing" class="service-icon icon-sm" />
          </div>
          <h3>Video Editing</h3>
        </div>
        <p>
          Focused edits, motion, and sound that give your story the pace and polish it deserves.
        </p>
      </div>
    </div>
  </div>

  <section class="spacer-block"></section>

  <section class="reveal-on-scroll">
    <CardSlider title="CodePen" icon="CodePen" link="https://codepen.io/emilandersson" linkLabel="View all →">
    {pens.map((pen) => (
      <CodePenCard
        slug={pen.slug}
        title={pen.title}
        user={codepenUser}
        src={thumbCache[pen.slug] || `https://shots.codepen.io/${codepenUser}/pen/${pen.slug}-512.webp`}
      />
    ))}
    </CardSlider>
  </section>

  <section class="spacer-block"></section>
</BaseLayout>

<script>
  import { initScramble } from '@scripts/text-scramble';

  const video = document.querySelector<HTMLVideoElement>('.hero-video');
  const buttonsEl = document.querySelector<HTMLElement>('[data-hero-buttons]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const animateButtons = () => {
    if (!buttonsEl) return;
    buttonsEl.style.opacity = '';
    buttonsEl.classList.add('anim-fade-up');
  };

  /** Unhide segments and kick off the scramble in the same JS frame. */
  const revealAndScramble = () => {
    document.querySelectorAll<HTMLElement>('.scramble-seg, .scramble-sep').forEach((el) => {
      el.style.opacity = '1';
    });
    initScramble();
  };

  let sequenceStarted = false;
  const startSequence = () => {
    if (sequenceStarted) return;
    sequenceStarted = true;

    if (prefersReducedMotion) {
      revealAndScramble();
      animateButtons();
      return;
    }

    // Step 1: fade in video (handled by BaseLayout)
    // Step 2: start scramble partway through video fade
    window.setTimeout(revealAndScramble, 600);

    // Step 3: animate buttons after scramble has run
    window.setTimeout(animateButtons, 1300);
  };

  if (!video) {
    revealAndScramble();
    animateButtons();
  } else if (video.readyState >= 3) {
    startSequence();
  } else {
    video.addEventListener('canplaythrough', startSequence, { once: true });
    // Fallback: run sequence even if video never fires canplaythrough
    window.setTimeout(startSequence, 3000);
  }
</script>
