---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import ToolIcon from '@components/ToolIcon.astro';
import profileImage from '@assets/emil-andersson-illustration.png';

const socials = [
  { name: 'X', url: 'https://x.com/bobemil_sw13', icon: 'x' },
  { name: 'GitHub', url: 'https://github.com/emilanderss0n', icon: 'github' },
  { name: 'CodePen', url: 'https://codepen.io/emilandersson', icon: 'codepen' },
];

const tools = ['Blender', 'Photoshop', 'VS Code', 'Chrome', 'GitHub'];
---

<BaseLayout title="About" description="Emil Andersson — UI Designer, Web Developer, 3D Artist, Video Editor">
  <section class="py-8 sm:py-12 md:py-20">

      <div class="flex flex-col sm:flex-row gap-5 sm:gap-6 md:gap-8 items-start mb-6">
        <div class="w-full sm:max-w-[50%] flex flex-col anim-slide-left" style="--anim-delay: 100ms">
          <div class="relative bg-gradient-to-br from-[var(--color-accent)]/20 via-[var(--color-accent)]/10 to-[var(--color-accent-2)]/10 rounded-2xl futuristic-br p-2">
            <div class="relative w-full sm:w-50 md:w-56 h-48 sm:h-52 md:h-56 rounded-xl futuristic-br overflow-hidden">
              <Image src={profileImage} alt="Emil Andersson" class="w-full h-full object-cover" densities={[1, 2]} format="webp" />
              <div class="absolute inset-0 bg-[var(--color-accent)]/15"></div>
            </div>
            <div class="flex gap-2 px-1.5 pt-2.5">
              {socials.map((s) => (
                <a href={s.url} target="_blank" rel="noopener noreferrer"
                   class="flex-1 h-10 sm:h-9 rounded-lg flex items-center justify-center futuristic-button text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-all duration-300"
                   title={s.name}>
                  {s.icon === 'x' && (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.176 4h2.76l-6.03 6.888L22 20.26h-5.554l-4.352-5.688L6.44 20.26H3.678l6.452-7.372L3.06 4h5.696l3.934 5.2L17.176 4zm-.575 14.612h1.53L8.178 5.564H6.518l10.083 13.048z"/></svg>
                  )}
                  {s.icon === 'github' && (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
                  )}
                  {s.icon === 'codepen' && (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/><polyline points="2 15.5 12 8.5 22 15.5"/><line x1="12" y1="2" x2="12" y2="8.5"/></svg>
                  )}
                </a>
              ))}
            </div>
          </div>
          <div class="pt-8 anim-fade-up" style="--anim-delay: 400ms">
            <h2 class="text-sm font-medium uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Preferred Toolset</h2>
            <div class="flex flex-wrap gap-3">
              {tools.map((tool) => (
                <div class="flex items-center gap-2.5 px-4 py-2.5 badge rounded-xl futuristic-br text-sm font-medium text-[var(--color-text)] cursor-default">
                  <ToolIcon name={tool} />
                  {tool}
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="anim-slide-right" style="--anim-delay: 180ms">
          <h1 class="text-3xl font-medium tracking-tight mb-1">Emil Andersson</h1>
          <p class="gradient-text font-display font-medium text-lg">UI Designer / Web Developer / 3D Artist / Video Editor</p>

          <div class="mt-5 space-y-4 text-[var(--color-text-muted)] leading-relaxed anim-fade-in" style="--anim-delay: 300ms">
            <p>
              Hello, I was born in Sweden 1989 in a small town named <strong class="text-[var(--color-text)]">Skänninge</strong>.
              I'm a simple guy that loves to be creative. There is something very fullfilling with writing code or creating art. Sometimes you help people with your creations, without even realizing it.
            </p>
            <p>
              At 20, fueled by youthful energy and a hunger for something more, a friend and I
              decided to start our own agency, which had the name <strong class="text-[var(--color-text)]">Delive - Web Solutions</strong>.
              Our first clients loved what we did with their digital identity (you can still see some of them
              cruising around with the branding we made for them even today). But after a few years, we both
              felt the need to move on.
            </p>
            <p>I wanted to explore the world of 3D art and game development.
              So I did. I've now worked with people from all over the world. Mostly on web design
              and game development projects. It's so fun meeting people with different backgrounds
              and ideas. It's like a never-ending source of inspiration.
            </p>
            <p>
              I'm on the lookout for creative opportunities or a chance to join your
              creative team. Proficient in web development, graphic design, video editing, and
              3D art, I'm poised to make a meaningful impact.
            </p>

            <div class="pt-4">
              <a href="mailto:hello@emils.graphics"
                 class="inline-flex items-center gap-3 px-5 py-3 rounded-xl futuristic-button text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-2)] no-underline group transition-all duration-300">
                <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-accent)]/10 group-hover:bg-[var(--color-accent)]/20 transition-colors shrink-0">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="M22 4L12 13 2 4"/>
                  </svg>
                </span>
                <span>
                  <span class="block text-[10px] text-[var(--color-text-muted)] font-normal uppercase tracking-wider">Get in touch</span>
                  <span class="text-[var(--color-accent)] group-hover:text-[var(--color-text)] transition-colors">hello@emils.graphics</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-20 flex flex-col lg:flex-row gap-6 items-stretch">
          <!-- Artist info card -->
          <div class="lg:w-80 shrink-0 glass-card futuristic-br p-6 flex flex-col items-center text-center anim-scale-in" style="--anim-delay: 500ms">
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[var(--color-accent)]/30 to-[var(--color-accent-2)]/30 flex items-center justify-center mb-4 ring-2 ring-[var(--color-border)]">
              <svg class="w-8 h-8 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.655 17.31c-.217.355-.677.467-1.032.25-2.828-1.725-6.39-2.115-10.58-1.16-.395.095-.795-.15-.89-.545-.095-.395.15-.795.545-.89 4.58-1.04 8.515-.595 11.707 1.355.355.215.467.68.25 1.03v-.04zm1.49-3.325c-.27.445-.85.585-1.295.315-3.24-1.99-8.18-2.565-12.01-1.405-.495.15-1.015-.105-1.17-.605-.155-.498.11-1.018.605-1.17 4.38-1.325 9.805-.68 13.555 1.59.445.27.585.855.315 1.295v-.02zm.13-3.475C15.38 8.19 8.715 7.945 4.05 9.36c-.605.185-1.245-.14-1.43-.745-.185-.605.14-1.245.745-1.43 5.36-1.63 12.685-1.315 17.585 1.905.55.33.73 1.035.4 1.585-.33.55-1.035.73-1.585.4l-.02-.015z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text)] mb-1">CIVIC</h3>
            <p class="text-xs text-[var(--color-text-muted)] mb-1">Electronic Dance Music</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              I've been creating electronic dance music since I was 15 years old. What started as FL Studio experiments grew into a full-on passion. Bring the vibe, feel the beat.
            </p>
            <a
              href="https://open.spotify.com/artist/5fLAJ1k3aPNR5akavV7gzD"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 rounded-xl futuristic-button text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-text)] no-underline transition-colors group"
            >
              <svg class="w-4 h-4 group-hover:text-[var(--color-accent-2)] transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.655 17.31c-.217.355-.677.467-1.032.25-2.828-1.725-6.39-2.115-10.58-1.16-.395.095-.795-.15-.89-.545-.095-.395.15-.795.545-.89 4.58-1.04 8.515-.595 11.707 1.355.355.215.467.68.25 1.03v-.04zm1.49-3.325c-.27.445-.85.585-1.295.315-3.24-1.99-8.18-2.565-12.01-1.405-.495.15-1.015-.105-1.17-.605-.155-.498.11-1.018.605-1.17 4.38-1.325 9.805-.68 13.555 1.59.445.27.585.855.315 1.295v-.02zm.13-3.475C15.38 8.19 8.715 7.945 4.05 9.36c-.605.185-1.245-.14-1.43-.745-.185-.605.14-1.245.745-1.43 5.36-1.63 12.685-1.315 17.585 1.905.55.33.73 1.035.4 1.585-.33.55-1.035.73-1.585.4l-.02-.015z"/></svg>
              Listen on Spotify ↗
            </a>
          </div>

          <!-- Spotify embed -->
          <div class="flex-1 min-w-0 glass-card futuristic-br overflow-hidden anim-slide-right p-3" style="--anim-delay: 600ms">
            <iframe
              data-testid="embed-iframe"
              style="border-radius:12px; display:block"
              src="https://open.spotify.com/embed/artist/5fLAJ1k3aPNR5akavV7gzD?utm_source=generator&theme=0&si=2abe8ce034274426"
              width="100%"
              height="352"
              frameborder="0"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>

  </section>
</BaseLayout>
