---
import '@styles/global.css';
import { Image } from 'astro:assets';
import ToolIcon from '@components/ToolIcon.astro';
import logoImage from '@assets/logo-2x.png';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Personal portfolio — curated content from across the web',
  ogImage = '/og/default.png',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const fullTitle = `${title} - Emil / Moxo`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Emil / Moxo" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Tektur — Google Fonts, weights 400–500 for headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tektur:wght@400..500&display=swap" rel="stylesheet" />
    <script>
      (function setupScrollReveal() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        function observeAll() {
          document.querySelectorAll('.reveal-on-scroll:not(.is-revealed)').forEach((el) => observer.observe(el));
        }
        observeAll();
        document.addEventListener('astro:page-load', observeAll);
        document.addEventListener('astro:after-swap', observeAll);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col relative z-0">
    <header class="relative z-10 max-w-5xl mx-auto w-full px-5 sm:px-6 py-3 sm:py-4 flex justify-between items-center" transition:persist>
      <a href="/" class="no-underline">
        <Image src={logoImage} alt="Emil" densities={[1, 2]} class="h-8 w-auto" />
      </a>
      <nav aria-label="Primary">
        <ul class="nav-pill flex items-center gap-1 list-none">
          <li>
            <a href="/"
               aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
               class:list={['nav-link', Astro.url.pathname === '/' ? 'nav-link--active' : '']}>Home</a>
          </li>
          <li>
            <a href="/about"
               aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}
               class:list={['nav-link', Astro.url.pathname === '/about' ? 'nav-link--active' : '']}>About</a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="relative z-10 flex-1 max-w-5xl mx-auto w-full px-5 sm:px-6 py-6 sm:py-8">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-[var(--color-border)]" transition:persist>
      <div class="max-w-5xl mx-auto w-full px-5 sm:px-6 py-6 sm:py-8 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="text-xs text-[var(--color-text-muted)]">
          <p>&copy; {new Date().getFullYear()} Emil. Built with Astro + Tailwind.</p>
        </div>
        <div class="flex items-center gap-5">
          <!-- Social links -->
          {
            [
              { name: 'X',          href: 'https://x.com/bobemil_sw13',            title: 'X (Twitter)' },
              { name: 'GitHub',     href: 'https://github.com/emilanderss0n',     title: 'GitHub' },
              { name: 'CodePen',    href: 'https://codepen.io/emilandersson',     title: 'CodePen' },
              { name: 'ArtStation', href: 'https://www.artstation.com/emils-graphics', title: 'ArtStation' },
              { name: 'Spotify',    href: 'https://open.spotify.com/artist/5fLAJ1k3aPNR5akavV7gzD?si=JsokA6jwROOmdjrIWG50ng', title: 'Spotify' },
            ].map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                title={link.title}
                class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300"
              >
                <ToolIcon name={link.name} class="w-5 h-5" />
                <span class="sr-only">{link.title}</span>
              </a>
            ))
          }
        </div>
      </div>
    </footer>
  </body>
</html>
