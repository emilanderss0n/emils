---
import '@styles/global.css';
import ToolIcon from '@components/ToolIcon.astro';
import heroVideo from '@assets/12149178_1920_1080_24fps.mp4';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Personal portfolio — curated content from across the web',
  ogImage = '/og/default.png',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const fullTitle = `${title} - Emil / Moxo`;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Emil / Moxo" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Tektur — Google Fonts, weights 400–500 for headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tektur:wght@400..500&display=swap" rel="stylesheet" />
    <script>
      (function setupScrollReveal() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        function observeAll() {
          document.querySelectorAll('.reveal-on-scroll:not(.is-revealed)').forEach((el) => observer.observe(el));
        }
        observeAll();
        document.addEventListener('astro:page-load', observeAll);
        document.addEventListener('astro:after-swap', observeAll);
      })();

      // Entrance animations (.anim-fade/-scale/-slide) use `fill: both`, which
      // leaves a lingering transform on the element. That transform makes the
      // element a "backdrop root", cutting the fixed hero video out of the
      // backdrop for any descendant using backdrop-filter (buttons, cards, etc.).
      // Once the animation ends, flag it so CSS can clear the transform.
      document.addEventListener('animationend', function (e) {
        var t = e.target;
        if (t instanceof HTMLElement && /(^|\s)anim-(fade|scale|slide)/.test(t.className)) {
          t.classList.add('anim-done');
        }
      });
    </script>
  </head>
  <body>
    <div class="site-video-bg" aria-hidden="true" transition:persist>
      <video class="hero-video" autoplay muted loop playsinline preload="none">
        <source data-src={heroVideo} type="video/mp4" />
      </video>
      <div class="hero-video-tint"></div>
      <div class="hero-video-vignette"></div>
    </div>
    <header transition:persist>
      <div class="cont">
        <a href="/" class="logo">
          <h1>Emil <span>/ Moxo</span></h1>
        </a>
        <nav aria-label="Primary">
          <ul class="nav-pill flex">
            <li>
              <a href="/"
                aria-current={currentPath === '/' ? 'page' : undefined}
                class:list={['nav-link', currentPath === '/' ? 'nav-link--active' : '']}>Home</a>
            </li>
            <li>
              <a href="/about"
                aria-current={currentPath === '/about' ? 'page' : undefined}
                class:list={['nav-link', currentPath === '/about' ? 'nav-link--active' : '']}>About</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer transition:persist>
      <div class="cont flex space-between">
        <div class="copyright">
          <p>&copy; {new Date().getFullYear()} Emil. Built with Astro.</p>
        </div>
        <div class="filter-nav flex items-center gap-md">
          <!-- Social links -->
          {
            [
              { name: 'X',          href: 'https://x.com/bobemil_sw13',            title: 'X (Twitter)' },
              { name: 'GitHub',     href: 'https://github.com/emilanderss0n',     title: 'GitHub' },
              { name: 'CodePen',    href: 'https://codepen.io/emilandersson',     title: 'CodePen' },
              { name: 'ArtStation', href: 'https://www.artstation.com/emils-graphics', title: 'ArtStation' },
              { name: 'Spotify',    href: 'https://open.spotify.com/artist/5fLAJ1k3aPNR5akavV7gzD?si=JsokA6jwROOmdjrIWG50ng', title: 'Spotify' },
            ].map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                title={link.title}
                class="btn sm"
              >
                <ToolIcon name={link.name} class="icon-sm" />
                <span class="sr-only">{link.title}</span>
              </a>
            ))
          }
        </div>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  (function () {
    var video = document.querySelector('.hero-video');
    var source = video && video.querySelector('source[data-src]');
    if (!video || !source) return;
    var show = function () { video.classList.add('is-loaded'); };
    var loadVideo = function () {
      if (source.src) return;
      var src = source.dataset.src;
      if (!src) return;
      source.src = src;
      video.load();
      if (video.readyState >= 3) { show(); return; }
      video.addEventListener('canplaythrough', show, { once: true });
      window.setTimeout(show, 3000);
    };
    var schedule = function () {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(loadVideo, { timeout: 2000 });
      } else {
        window.setTimeout(loadVideo, 0);
      }
    };
    if (document.readyState === 'complete') schedule();
    else window.addEventListener('load', schedule, { once: true });
  })();
</script>
