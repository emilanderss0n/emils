---
// RepoCard.astro — reusable card for GitHub repo listings
import type { CollectionEntry } from 'astro:content';

interface Props {
  repo: CollectionEntry<'repos'>;
  delay?: number;
}

const { repo, delay } = Astro.props;
---

<a href={repo.data.url} target="_blank" rel="noopener noreferrer" class="card repo-card anim-scale-in" data-lang={repo.data.language} data-category={repo.data.category} style={delay != null ? `--anim-delay: ${delay}ms` : undefined}>
  <div class="content flex-column gap-md">
    <h3>
      {repo.data.name}
    </h3>
    {repo.data.description && (
      <p>{repo.data.description}</p>
    )}
    <div class="flex space-between" style="margin-top: auto;">
      <span class="flex gap-xs meta">
        <svg class="icon-xs" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
        </svg>
        {new Date(repo.data.pushedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </span>
      <span class="badge futuristic-br">{repo.data.language}</span>
    </div>
  </div>
</a>

<style>
  .repo-card {
    display: block;
    color: var(--color-text);
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .repo-card:hover {
    background: var(--color-ghost-bg);
    color: var(--color-text);
  }

  .repo-card h3 {
    transition: color 0.2s;
  }

  .repo-card:hover h3 {
    color: var(--color-accent);
  }
</style>
