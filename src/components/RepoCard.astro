---
// RepoCard.astro — reusable card for GitHub repo listings
import type { CollectionEntry } from 'astro:content';

interface Props {
  repo: CollectionEntry<'repos'>;
}

const { repo } = Astro.props;
---

<article class="repo-card glass-card p-6 flex flex-col anim-scale-in" data-lang={repo.data.language} data-category={repo.data.category}>
  <div class="flex items-start justify-between mb-3">
    <span class="badge">{repo.data.language}</span>
    <span class="badge badge--muted">★ {repo.data.stars}</span>
  </div>
  <h3 class="text-base font-semibold mb-2 leading-snug">
    <a href={repo.data.url} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline transition-colors">
      {repo.data.name}
    </a>
  </h3>
  {repo.data.description && (
    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{repo.data.description}</p>
  )}
  <div class="mt-4 pt-3 border-t border-[var(--color-border)] text-xs text-[var(--color-text-muted)]">
    Updated {new Date(repo.data.pushedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
  </div>
</article>
