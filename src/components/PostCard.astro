---
// PostCard.astro — reusable card for post listings
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
---

<article class="glass-card p-6 flex flex-col hover:border-[var(--color-border-hover)] transition-colors duration-300">
  <div class="flex items-center gap-2 mb-3">
    {post.data.tags.slice(0, 2).map((tag: string) => (
      <span class="badge">{tag}</span>
    ))}
  </div>
  <h3 class="text-base font-semibold mb-2 leading-snug">
    <a href={`/posts/${post.id.replace(/\.md$/, '')}`} class="text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline transition-colors">
      {post.data.title}
    </a>
  </h3>
  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{post.data.description}</p>
  <div class="mt-4 pt-3 border-t border-[var(--color-border)] text-xs text-[var(--color-text-muted)]">
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
</article>
