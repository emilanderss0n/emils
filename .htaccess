RewriteEngine On
RewriteBase /

# --------------------------------------------------------------------
# ROUTING — silently serve from dist/ without exposing folder name
# --------------------------------------------------------------------
# If the request maps to a real file/dir inside dist/, rewrite it there.
# The %{ENV:REDIRECT_STATUS} check prevents looping.
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
RewriteRule ^ %{REQUEST_URI}/.  [L,DPI]

RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_URI} !^/dist/
RewriteRule ^(.*)$ /dist/$1 [L]

# --------------------------------------------------------------------
# TRAILING SLASH — redirect cleanly before mod_dir exposes /dist/
# --------------------------------------------------------------------
RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
RewriteRule ^(.+[^/])$ /$1/ [R=301,L]
